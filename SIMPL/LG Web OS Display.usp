#SYMBOL_NAME "LG WebOS Display"

#USER_SIMPLSHARP_LIBRARY "LgWebOs"

#DEFAULT_VOLATILE
#ENABLE_STACK_CHECKING
#ENABLE_TRACE

Digital_Input PowerOn, PowerOff, _skip_, VolumeUp, VolumeDown, VolumeMuteOn, VolumeMuteOff;
Digital_Input _skip_, KeyUp, KeyDown, KeyLeft, KeyRight, KeyHome, KeyBack, KeySelect, KeyExit, KeyInfo, KeyMenu, KeyRed, KeyGreen, KeyYellow, KeyBlue, KeyPlay, KeyPause, KeyStop;
Digital_Input _skip_, Key0, Key1, Key2, Key3, Key4, Key5, Key6, Key7, Key8, Key9;
Digital_Input _skip_, GetInputs, GetApps;
Analog_Input SetVolume, ChangeInput, LaunchApp;
String_Input _skip_, SendNotification[100];

Digital_Output PowerIsOn, PowerIsOff, _skip_, MuteIsOn, MuteIsOff;
Analog_Output VolumeValue;
Analog_Output _skip_, _skip_, _skip_,  _skip_, _skip_, _skip_, _skip_, _skip_, _skip_, _skip_, _skip_, _skip_, _skip_, _skip_, _skip_, _skip_, _skip_, _skip_, _skip_, _skip_,_skip_, _skip_, _skip_,_skip_, _skip_, _skip_, _skip_, _skip_, _skip_, _skip_, _skip_,  TotalInputs, TotalApps, _skip_, CurrentInput;
String_Output InputNamesXsig, InputIconsXsig, AppNamesXsig, AppIconsXsig;

Display _disp;

String_Parameter _skip_, _skip_, _skip_, _skip_, _skip_, _skip_, _skip_, _skip_, _skip_, _skip_, _skip_, _skip_, _skip_, _skip_, _skip_, _skip_, _skip_, _skip_, _skip_, _skip_, _skip_, _skip_, _skip_, _skip_, _skip_, _skip_, _skip_, _skip_, _skip_, _skip_, _skip_, _skip_, _skip_, _skip_, _skip_, _skip_, _skip_, _skip_, _skip_, _skip_, _skip_, _skip_, _skip_, _skip_, _skip_, ID[100], IpAddress[100], MacAddress[100];
Integer_Parameter Port, VolumeRepeatTime, DebugMode;

#BEGIN_PARAMETER_PROPERTIES VolumeRepeatTime
propDefaultValue=10d;
#END_PARAMETER_PROPERTIES

#BEGIN_PARAMETER_PROPERTIES Port
propDefaultValue=3000d;
#END_PARAMETER_PROPERTIES

integer newDirection;

function VolumeRepeat(integer direction)
{
	newDirection = direction;
	
	if(newDirection = 1)
	_disp.IncrementVolume();
	else if(newDirection = 0)
	_disp.DecrementVolume();
	
	wait(VolumeRepeatTime, vRepeat)
	{
		VolumeRepeat(newDirection);
	}
}

Push PowerOn
{
	_disp.PowerOn();
}

Push PowerOff
{
	_disp.PowerOff();
}

Push VolumeUp
{
	VolumeRepeat(1);
}

Release VolumeUp
{
	CancelWait(vRepeat);
}

Push VolumeDown
{
	VolumeRepeat(0);
}

Release VolumeDown
{
	CancelWait(vRepeat);
}

Push VolumeMuteOn
{
	_disp.SetMute(1);
}

Push VolumeMuteOff
{
	_disp.SetMute(0);
}

Push KeyUp
{
	_disp.SendKey("UP");
}

Push KeyDown
{
	_disp.SendKey("DOWN");
}

Push KeyLeft
{
	_disp.SendKey("LEFT");
}

Push KeyRight
{
	_disp.SendKey("RIGHT");
}

Push KeyHome
{
	_disp.SendKey("HOME");
}

Push KeyBack
{
	_disp.SendKey("BACK");
}

Push KeySelect
{
	_disp.SendKey("ENTER");
}

Push KeyExit
{
	_disp.SendKey("EXIT");
}

Push KeyInfo
{
	_disp.SendKey("INFO");
}

Push KeyMenu
{
	_disp.SendKey("MENU");
}

Push KeyRed
{
	_disp.SendKey("RED");
}

Push KeyGreen
{
	_disp.SendKey("GREEN");
}

Push KeyYellow
{
	_disp.SendKey("YELLOW");
}

Push KeyBlue
{
	_disp.SendKey("BLUE");
}

Push KeyPlay
{
	_disp.SendKey("PLAY");
}

Push KeyPause
{
	_disp.SendKey("PAUSE");
}
Push KeyStop
{
	_disp.SendKey("STOP");
}

Push Key0
{
	_disp.SendKey("0");
}

Push Key1
{
	_disp.SendKey("1");
}

Push Key2
{
	_disp.SendKey("2");
}

Push Key3
{
	_disp.SendKey("3");
}

Push Key4
{
	_disp.SendKey("4");
}

Push Key5
{
	_disp.SendKey("5");
}

Push Key6
{
	_disp.SendKey("6");
}

Push Key7
{
	_disp.SendKey("7");
}

Push Key8
{
	_disp.SendKey("8");
}

Push Key9
{
	_disp.SendKey("9");
}

Push GetInputs
{
	_disp.GetInputs();
}

Push GetApps
{
	_disp.GetApps();
	
}

change SetVolume
{
	_disp.SetVolume(SetVolume);
}

Change ChangeInput
{
	_disp.ChangeInput(ChangeInput);
}

Change LaunchApp
{
	_disp.LaunchApp(LaunchApp);
}

Change SendNotification
{
	_disp.SendNotification(SendNotification);
}

eventhandler OnPowerStateChanged(Display sender,UShortEventArgs args)
{
	
}

eventhandler newPowerState(Display sender, UShortEventArgs args)
{
	if(args.Payload)
	{
		PowerIsOff = OFF;
		PowerIsOn = ON; 
	}
	else
	{
		PowerIsOn = OFF;
		PowerIsOff = ON;
	}
}

eventhandler newVolumeValue(Display sender, UShortEventArgs args)
{
	VolumeValue = args.Payload;
}

eventhandler newVolumeMuteState(Display sender, UShortEventArgs args)
{
	if(args.Payload)
	{
		MuteIsOff = OFF;
		MuteIsOn = ON;
	}
	else
	{
		MuteIsOn = OFF;
		MuteIsOff = ON;
	}
}

eventhandler newCurrentInputValue(Display sender, UShortEventArgs args)
{
	CurrentInput = args.Payload + 1;
}

eventhandler newInputCount(Display sender, UShortEventArgs args)
{
	TotalInputs = args.Payload;
}

eventhandler newExternalInputNames(Display sender, StringEventArgs args)
{
	InputNamesXsig = args.Payload;
}

eventhandler newExternalInputIcons(Display sender, StringEventArgs args)
{
	InputIconsXsig = args.Payload;
}

eventhandler newAppCount(Display sender, UShortEventArgs args)
{
	TotalApps = args.Payload;
}

eventhandler newAppNames(Display sender, StringEventArgs args)
{
	AppNamesXsig = args.Payload;
}

eventhandler newAppIcons(Display sender, StringEventArgs args)
{
	AppIconsXsig = args.Payload;
}

Function Main()
{
	WaitForInitializationComplete();
	
	_disp.DebugMode = DebugMode;
	
	RegisterEvent(_disp, PowerStateChanged, newPowerState);
    RegisterEvent(_disp, VolumeValueChanged, newVolumeValue);
    RegisterEvent(_disp, VolumeMuteStateChanged, newVolumeMuteState);
    RegisterEvent(_disp, CurrentInputValueChanged, newCurrentInputValue);
    RegisterEvent(_disp, InputCountChanged, newInputCount);
    RegisterEvent(_disp, ExternalInputNamesChanged, newExternalInputNames);
    RegisterEvent(_disp, ExternalInputIconsChanged, newExternalInputIcons);
    RegisterEvent(_disp, AppCountChanged, newAppCount);
    RegisterEvent(_disp, AppIconsChanged, newAppIcons);
    RegisterEvent(_disp, AppNamesChanged, newAppNames);
	
	_disp.Initialize(ID, IpAddress, Port, MacAddress);
}
